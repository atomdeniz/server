# Traefik integration overlay for the official Supabase compose
# Disables unused services (replaced with busybox noop) and configures Traefik routing.
# Only db, rest, auth, kong remain active.

services:

  # --- Disabled services (noop containers that satisfy dependency chains) ---

  studio:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}
    volumes: !reset []

  realtime:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}

  storage:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}
    volumes: !reset []

  imgproxy:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    environment: !reset {}
    volumes: !reset []

  meta:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}

  functions:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}
    volumes: !reset []
    command: !reset []

  analytics:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}

  vector:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    environment: !reset {}
    volumes: !reset []
    command: !reset []
    security_opt: !reset []

  supavisor:
    image: busybox:latest
    entrypoint: ["true"]
    restart: "no"
    healthcheck:
      disable: true
    depends_on: !reset {}
    environment: !reset {}
    volumes: !reset []
    ports: !reset []
    command: !reset []

  # --- Active services (remove analytics/vector dependencies) ---

  db:
    depends_on: !reset {}

  rest:
    depends_on: !reset
      db:
        condition: service_healthy

  auth:
    depends_on: !reset
      db:
        condition: service_healthy

  kong:
    depends_on: !reset
      auth:
        condition: service_healthy
      rest:
        condition: service_started
    networks:
      - default
      - app_network
    labels:
      traefik.enable: "true"
      traefik.docker.network: "app_network"
      traefik.http.routers.supabase-api.entrypoints: "https"
      traefik.http.routers.supabase-api.rule: "Host(`{{ supabase_api_host }}`)"
      traefik.http.routers.supabase-api.tls: "true"
      traefik.http.routers.supabase-api.service: "supabase-api"
      traefik.http.routers.supabase-api.middlewares: "api-external@file"
      traefik.http.services.supabase-api.loadbalancer.server.port: "8000"
      wud.watch: "false"

networks:
  app_network:
    external: true
