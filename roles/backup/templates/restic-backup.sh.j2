#!/usr/bin/env bash
set -euo pipefail

REPO="{{ restic_repo_path }}"
PASSWORD_FILE="/etc/restic-password"
DUMP_DIR="{{ restic_db_dump_dir }}"
MAILTO="{{ email_recipient }}"
HOSTNAME=$(hostname)

export RESTIC_REPOSITORY="$REPO"
export RESTIC_PASSWORD_FILE="$PASSWORD_FILE"
export RESTIC_COMPRESSION="auto"

send_mail() {
  local subject="$1"
  local body="$2"
  echo -e "Subject: $subject\n\n$body" | msmtp "$MAILTO"
}

LOG=$(mktemp)
STATUS="SUCCESS"

{
  echo "[$(date)] Starting backup..."

  # Pre-backup: dump PostgreSQL (Immich)
  if docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q '^{{ postgres_container_name }}$'; then
    echo "Dumping PostgreSQL..."
    docker exec {{ postgres_container_name }} pg_dumpall -U {{ postgres_bootstrap_user }} > "$DUMP_DIR/postgres.sql"
  fi

  # Pre-backup: dump MariaDB (Seafile)
  if docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q '^seafile-mysql$'; then
    echo "Dumping Seafile MariaDB..."
    docker exec seafile-mysql mariadb-dump -u root -p"{{ seafile_db_root_password }}" --all-databases > "$DUMP_DIR/seafile-mariadb.sql"
  fi

  # Pre-backup: dump PostgreSQL (Supabase)
  if docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q '^supabase-db$'; then
    echo "Dumping Supabase PostgreSQL..."
    docker exec supabase-db pg_dumpall -U postgres > "$DUMP_DIR/supabase-postgres.sql"
  fi

  # Run backup
  restic backup {{ restic_backup_path }} \
{% for path in restic_exclude_paths %}
    --exclude "{{ path }}" \
{% endfor %}
    --tag automated

  # Apply retention policy
  restic forget \
    --keep-daily {{ restic_keep_daily }} \
    --keep-weekly {{ restic_keep_weekly }} \
    --keep-monthly {{ restic_keep_monthly }} \
    --prune

  # Snapshot summary
  restic snapshots --latest 1

  echo "[$(date)] Backup complete."
} > "$LOG" 2>&1 || STATUS="FAILED"

send_mail "[$STATUS] Backup - $HOSTNAME - $(date +%Y-%m-%d)" "$(cat "$LOG")"
rm -f "$LOG"

[ "$STATUS" = "SUCCESS" ] || exit 1
