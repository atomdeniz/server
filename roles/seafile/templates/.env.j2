#################################
# Docker compose configurations #
#################################
COMPOSE_FILE='seafile-server.yml'
COMPOSE_PATH_SEPARATOR=','

## Images
SEAFILE_IMAGE=seafileltd/seafile-mc:{{ seafile_version }}
SEAFILE_DB_IMAGE=mariadb:{{ mariadb_version }}
## Persistent Storage
SEAFILE_VOLUME={{ docker_dir }}/seafile/shared
SEAFILE_MYSQL_VOLUME={{ docker_dir }}/seafile/db

#################################
#      Startup parameters       #
#################################
SEAFILE_SERVER_HOSTNAME={{ seafile_host }}
SEAFILE_SERVER_PROTOCOL=https
TIME_ZONE=Europe/Istanbul
JWT_PRIVATE_KEY={{ seafile_jwt_private_key }}

#####################################
# Third-party service configuration #
#####################################

## Database
SEAFILE_MYSQL_DB_HOST=db
SEAFILE_MYSQL_DB_USER=seafile
SEAFILE_MYSQL_DB_PASSWORD={{ seafile_db_root_password }}
SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db

## Cache
CACHE_PROVIDER=redis

### Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

######################################
#        Initial variables           #
# (Only valid in first-time startup) #
######################################

## Database root password
INIT_SEAFILE_MYSQL_ROOT_PASSWORD={{ seafile_db_root_password }}

## Seafile admin user
INIT_SEAFILE_ADMIN_EMAIL={{ seafile_admin_email }}
INIT_SEAFILE_ADMIN_PASSWORD={{ seafile_admin_password }}

############################################
# Additional configurations for extensions #
############################################

## SeaDoc service
ENABLE_SEADOC=false

## Notification
ENABLE_NOTIFICATION_SERVER=false

## Seafile AI
ENABLE_SEAFILE_AI=false
ENABLE_FACE_RECOGNITION=false

## Metadata server
MD_FILE_COUNT_LIMIT=100000
