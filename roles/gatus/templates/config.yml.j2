---
storage:
  type: sqlite
  path: /data/data.db

alerting:
  telegram:
    token: "{{ telegram_alert_bot_token }}"
    id: "{{ telegram_user_id }}"
    default-alert:
      enabled: true
      failure-threshold: 3
      success-threshold: 2
      send-on-resolved: true
      description: "health check failed"

ui:
  title: Status
  header: Status

endpoints:
  - name: Traefik
    group: Infrastructure
    url: "http://traefik:80"
    interval: 5m
    client:
      ignore-redirect: true
    conditions:
      - "[CONNECTED] == true"
      - "[STATUS] < 500"
    alerts:
      - type: telegram

  - name: Authelia
    group: Infrastructure
    url: "https://{{ authelia_host }}"
    interval: 5m
    conditions:
      - "[CONNECTED] == true"
      - "[STATUS] < 500"
    alerts:
      - type: telegram

  - name: AdGuard Home
