      - "[CONNECTED] == true"
    alerts:
      - type: ntfy

  # External. Suspension or node outage on Ultra.cc returns 502 at the
  # proxy layer — [STATUS] < 500 catches that. Public URL (no internal
  # Docker shortcut possible) and no auth required on the root path.
  - name: Seedbox (Ultra.cc)
    group: Infrastructure
    url: "https://{{ seedbox_user }}.{{ seedbox_host }}/"
    interval: 10m
    conditions:
      - "[CONNECTED] == true"
      - "[STATUS] < 500"
    alerts:
      - type: ntfy
