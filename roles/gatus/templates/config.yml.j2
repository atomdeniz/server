---
storage:
  type: sqlite
  path: /data/data.db

alerting:
  ntfy:
    url: "http://ntfy:80"
    topic: "{{ ntfy_topic_prefix }}gatus"
    priority: 4
    token: "{{ ntfy_token }}"
    default-alert:
      enabled: true
      failure-threshold: 3
      success-threshold: 2
      send-on-resolved: true
      description: "health check failed"

ui:
  title: Status
  header: Status

endpoints:
  - name: Traefik
    group: Infrastructure
    url: "http://traefik:80"
    interval: 5m
    client:
      ignore-redirect: true
    conditions:
      - "[CONNECTED] == true"
      - "[STATUS] < 500"
    alerts:
      - type: ntfy

  - name: Authelia
    group: Infrastructure
    url: "https://{{ authelia_host }}"
    interval: 5m
    conditions:
      - "[CONNECTED] == true"
      - "[STATUS] < 500"
    alerts:
      - type: ntfy

  - name: AdGuard Home
