    url: "http://adguardhome:3000"
    interval: 5m
    conditions:
      - "[STATUS] < 500"
    alerts:
      - type: ntfy

  - name: Homepage
    group: Applications
    url: "http://homepage:3000"
    interval: 5m
    conditions:
      - "[STATUS] == 200"
    alerts:
      - type: ntfy

  - name: Vaultwarden
