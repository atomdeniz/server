# Django
DEBUG=False
WGER_SECRET_KEY={{ wger_secret_key }}
WGER_TIME_ZONE={{ wger_timezone }}
WGER_USE_GUNICORN=True

# PostgreSQL
WGER_DB_ENGINE=django.db.backends.postgresql
WGER_DB_DATABASE={{ wger_db_name }}
WGER_DB_USER={{ wger_db_user }}
WGER_DB_PASSWORD={{ wger_db_password }}
WGER_DB_HOST={{ wger_db_host }}
WGER_DB_PORT=5432

# Redis
WGER_CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
WGER_CACHE_LOCATION={{ wger_redis_url }}

# Runtime
WGER_PERFORM_MIGRATIONS=True
WGER_MEDIA_ROOT=/home/wger/media
WGER_STATIC_ROOT=/home/wger/static
